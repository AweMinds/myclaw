# ===== 必填 =====

# 飞书应用配置（在 https://open.feishu.cn/ 创建企业自建应用）
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxx

# Anthropic API（Claude Code + 主模型）
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
# 可选：自定义 API 端点（默认 https://api.anthropic.com）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ===== 可选 =====

# OpenAI 兼容 API（备用模型）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gateway 认证令牌（不设置则自动生成）
# OPENCLAW_GATEWAY_TOKEN=your_token_here
